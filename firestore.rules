rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Authentication helper function
    function isAuthenticated() {
      return request.auth != null;
    }

    function isServiceAccount() {
      return request.auth.token.iss == 'https://accounts.google.com' &&
             request.auth.token.firebase.identities.size() > 0;
    }

    // Shipments collection: Authenticated users can read/write
    // Service accounts (Cloud Run) have full access via OIDC
    match /shipments/{shipmentId} {
      allow read, write: if isAuthenticated() || isServiceAccount();
    }

    // System configuration: Read for authenticated, Write restricted
    match /system/{document=**} {
      allow read: if isAuthenticated() || isServiceAccount();
      allow write: if isServiceAccount();
    }
  }
}
